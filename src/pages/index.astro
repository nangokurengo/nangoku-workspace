---
import Layout from '../layouts/Layout.astro';
import PhotoCard from '../components/PhotoCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/boeing_787_sunset.png';

// Fetch and sort content collections
const allPhotos = await getCollection('photos');
const latestPhotos = allPhotos
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const allBlogPosts = await getCollection('blog');
const latestBlog = allBlogPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<Layout title="Home" description="nangoku workspace - 10年以上のキャリアを持つ航空機写真の作品性と、自宅サーバーや自作キーボード等の技術力を同列に魅せるハイブリッドな秘密基地。">
  <!-- Hero Area -->
  <section class="max-w-7xl mx-auto px-6 mb-16 relative">
    <div class="relative rounded-3xl overflow-hidden aspect-auto md:aspect-[21/9] min-h-[400px] md:min-h-[350px] border border-white/10 glow-border">
      <!-- Background Image with Zoom & Dark Overlay -->
      <div class="absolute inset-0 z-0">
        <Image 
          src={heroImage} 
          alt="Boeing 787 sunset hero"
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/70 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent"></div>
      </div>

      <!-- Hero Content -->
      <div class="absolute inset-y-0 left-0 z-10 flex flex-col justify-center px-6 sm:px-16 w-full md:max-w-2xl text-left">
        <span class="text-brand-blue text-xs uppercase tracking-widest font-extrabold mb-3">
          ✈️ Aviation Creator & Engineer
        </span>
        <h1 class="text-3xl sm:text-5xl font-black text-white tracking-tight leading-tight font-sans">
          nangoku<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-blue via-brand-purple to-brand-neon">workspace</span>
        </h1>
        <p class="text-slate-300 text-sm sm:text-base mt-4 leading-relaxed font-sans font-light break-words whitespace-normal">
          10年以上のキャリアを持つ航空機写真の圧倒的な美しさと、自宅サーバー（Ubuntu/Docker）やガジェット、モノづくりに関わる技術力を同列に魅せるハイブリッドな秘密基地。
        </p>
        <div class="flex flex-wrap items-center gap-4 mt-6">
          <a href="/photos" class="px-5 py-2.5 rounded-xl bg-brand-blue hover:bg-brand-blue/80 text-slate-950 text-sm font-semibold tracking-wide shadow-lg shadow-brand-blue/20 hover:scale-[1.02] transition-all duration-300">
            View Gallery
          </a>
          <a href="/blog" class="px-5 py-2.5 rounded-xl border border-white/10 hover:border-brand-purple/40 bg-white/5 hover:bg-brand-purple/10 text-white text-sm font-semibold tracking-wide hover:scale-[1.02] transition-all duration-300">
            Read Technical Blog
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Tech & Photo Hybrid Section -->
  <section class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <!-- Latest Photos: 2 Columns Grid on the Left (occupying 2 columns space on lg) -->
      <div class="lg:col-span-2 space-y-6">
        <div class="flex items-center justify-between border-b border-white/5 pb-4">
          <h2 class="text-xl font-bold tracking-wide text-white flex items-center gap-2">
            <span class="text-brand-blue">Latest</span> Photos
          </h2>
          <a href="/photos" class="text-xs text-brand-blue hover:text-brand-neon transition-colors duration-200 flex items-center gap-1 font-semibold uppercase">
            All Photos
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {latestPhotos.map((photo) => (
            <PhotoCard photo={photo} />
          ))}
        </div>
      </div>

      <!-- Latest Tech Blog: 1 Column List on the Right -->
      <div class="space-y-6">
        <div class="flex items-center justify-between border-b border-white/5 pb-4">
          <h2 class="text-xl font-bold tracking-wide text-white flex items-center gap-2">
            <span class="text-brand-purple">Tech</span> Blog
          </h2>
          <a href="/blog" class="text-xs text-brand-purple hover:text-brand-purple/80 transition-colors duration-200 flex items-center gap-1 font-semibold uppercase">
            All Posts
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>

        <div class="flex flex-col gap-6">
          {latestBlog.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
