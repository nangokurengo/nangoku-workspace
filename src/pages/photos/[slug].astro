---
import Layout from '../../layouts/Layout.astro';
import ExifTable from '../../components/ExifTable.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const photos = await getCollection('photos');
  return photos.map((photo) => ({
    params: { slug: photo.id },
    props: { photo },
  }));
}

const { photo } = Astro.props;
const { data } = photo;

const siteUrl = Astro.site || 'https://nangoku-workspace.pages.dev';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteImageUrl = new URL(data.image.src, siteUrl).toString();

// Generate dynamic JSON-LD ImageObject schema for Google Crawler
const jsonLdSchema = {
  "@context": "https://schema.org",
  "@type": "ImageObject",
  "name": data.title,
  "url": canonicalURL,
  "contentUrl": absoluteImageUrl,
  "description": data.description || `${data.title} - Aviation photography at ${data.location}`,
  "dateCreated": data.date.toISOString().split('T')[0],
  "contentLocation": {
    "@type": "Place",
    "name": data.location
  },
  "creator": {
    "@type": "Person",
    "name": "nangoku"
  },
  "exifData": [
    {
      "@type": "PropertyValue",
      "name": "Camera",
      "value": data.exif.camera
    },
    {
      "@type": "PropertyValue",
      "name": "Lens",
      "value": data.exif.lens
    },
    {
      "@type": "PropertyValue",
      "name": "Shutter Speed",
      "value": data.exif.shutter
    },
    {
      "@type": "PropertyValue",
      "name": "Aperture",
      "value": data.exif.aperture
    },
    {
      "@type": "PropertyValue",
      "name": "ISO Sensitivity",
      "value": `ISO ${data.exif.iso}`
    },
    {
      "@type": "PropertyValue",
      "name": "Focal Length",
      "value": data.exif.focalLength
    }
  ]
};

const shareUrl = encodeURIComponent(Astro.url.href);
const shareText = encodeURIComponent(`${data.title} - nangoku workspace`);
const xShareUrl = `https://x.com/intent/post?url=${shareUrl}&text=${shareText}`;
---

<Layout 
  title={data.title} 
  description={data.description ? data.description.slice(0, 120) : `${data.title} - 撮影地: ${data.location}`}
  image={data.image.src}
  type="article"
>
  <!-- Injecting JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLdSchema)} />

  <div class="max-w-6xl mx-auto px-6">
    <!-- Back to gallery button -->
    <div class="mb-6">
      <a href="/photos" class="text-xs text-slate-400 hover:text-brand-blue transition-colors duration-250 flex items-center gap-1 font-semibold uppercase w-fit">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Gallery
      </a>
    </div>

    <!-- Main Display Section -->
    <div class="flex flex-col items-center">
      <!-- Title -->
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white text-center tracking-wide font-sans mb-8">
        {data.title}
      </h1>

      <!-- Optimized Photo Frame -->
      <div class="w-full rounded-2xl overflow-hidden glass border border-white/10 glow-border bg-slate-950 flex items-center justify-center p-2 sm:p-4">
        <Image 
          src={data.image} 
          alt={data.title}
          width={1600}
          height={1200}
          class="w-full h-auto rounded-xl object-contain max-h-[80vh] shadow-2xl"
          loading="eager"
        />
      </div>

      <!-- Exif Details & Episode Component -->
      <ExifTable 
        exif={data.exif}
        location={data.location}
        date={data.date}
        description={data.description}
      />

      <!-- Share Section -->
      <div class="border-t border-white/5 pt-8 mt-12 w-full max-w-5xl flex flex-col items-center gap-4">
        <p class="text-xs text-slate-500 font-sans uppercase tracking-widest">Share this photo</p>
        <a
          href={xShareUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-4 py-2.5 rounded-lg bg-neutral-800 hover:bg-neutral-700 transition-colors duration-200 text-white font-sans text-sm font-medium border border-white/5 shadow-md"
        >
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          <span class="text-neutral-500">|</span>
          <span>ポスト</span>
        </a>
      </div>
    </div>
  </div>
</Layout>
