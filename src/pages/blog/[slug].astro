---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const formattedDate = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(data.pubDate);

const categoryColors: Record<string, string> = {
  gadget: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
  server: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  review: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
  technology: 'bg-pink-500/10 text-pink-400 border-pink-500/20',
  photography: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
  custom: 'bg-slate-500/10 text-slate-400 border-slate-500/20',
};

const categoryBadgeColor = categoryColors[data.category] || categoryColors.custom;
---

<Layout 
  title={data.title} 
  description={data.description}
  image={data.coverImage ? data.coverImage.src : undefined}
  type="article"
>
  <article class="max-w-4xl mx-auto px-6">
    <!-- Back to blog button -->
    <div class="mb-6">
      <a href="/blog" class="text-xs text-slate-400 hover:text-brand-purple transition-colors duration-250 flex items-center gap-1 font-semibold uppercase w-fit">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>
    </div>

    <!-- Article Header -->
    <header class="border-b border-white/5 pb-8 mb-12">
      <div class="flex items-center gap-3 text-xs mb-4">
        <span class={`px-2.5 py-0.5 rounded-full border text-[11px] font-semibold uppercase ${categoryBadgeColor}`}>
          {data.category}
        </span>
        <span class="text-slate-400 font-sans">{formattedDate}</span>
      </div>
      <h1 class="text-2xl sm:text-4xl font-extrabold text-white tracking-wide font-sans mb-6 leading-tight">
        {data.title}
      </h1>
      
      {data.tags && data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {data.tags.map((tag) => (
            <span class="bg-white/5 text-slate-400 text-xs px-2.5 py-1 rounded-md">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Cover Image -->
    {data.coverImage && (
      <div class="w-full rounded-2xl overflow-hidden glass border border-white/10 glow-border bg-slate-950 mb-12 flex justify-center p-2">
        <Image
          src={data.coverImage}
          alt={data.title}
          width={1200}
          height={630}
          class="w-full h-auto rounded-xl max-h-[60vh] object-cover"
          loading="eager"
        />
      </div>
    )}

    <!-- Dynamic Render Content -->
    <div class="prose prose-invert max-w-none font-sans leading-relaxed">
      <Content />
    </div>
  </article>
</Layout>
